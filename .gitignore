# Secrets - HF_TOKEN for the Branch 3 VLM call lives here. Never commit.
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Generated evaluation artefacts (rebuild with the scripts in evaluation/).
# The trained anomaly engine is NOT ignored: backend/anomaly_engine.py needs it
# at inference time, so the deployed dashboard needs it in the repo. Without it
# every page raises EngineUnavailable.
evaluation/artifacts/*
!evaluation/artifacts/engine.pkl
!evaluation/artifacts/lstm.pt
!evaluation/artifacts/lstm_weights.npz
evaluation/pii_testset/
evaluation/data/*.csv
evaluation/data/vlm_cache/
# Per-model PII CSV variants; the canonical pii_scan_results_v2_real.csv is kept.
pii_scan_results_v2_*-*.csv
